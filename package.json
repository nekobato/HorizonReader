{
  "name": "oneline-browser",
  "productName": "Oneline Browser",
  "version": "0.1.0",
  "description": "A compact Electron browser for reading one line of web text at a time.",
  "author": "nekobato",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "npm run build && electron-builder --mac --dir --publish never --config.mac.identity=null",
    "dist": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never --config.mac.identity=null",
    "publish:github": "npm run build && electron-builder --mac --publish always",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "build": {
    "appId": "com.nekobato.oneline-browser",
    "productName": "Oneline Browser",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "artifactName": "Oneline-Browser-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "CFBundleName": "Oneline Browser",
        "CFBundleDisplayName": "Oneline Browser"
      }
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nekobato",
        "repo": "OnelineBrowser",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@iconify-json/mingcute": "^1.2.7",
    "@iconify/vue": "^5.0.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "electron": "^43.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  }
}
